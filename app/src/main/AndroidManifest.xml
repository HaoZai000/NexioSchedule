<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-sdk tools:overrideLibrary="top.yukonga.miuix.kmp.blur" />

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.课程表">
        <activity
            android:name=".ui.activities.MainActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|mnc|colorMode|density|fontScale|fontWeightAdjustment|keyboard|layoutDirection|locale|mcc|navigation|smallestScreenSize|touchscreen|uiMode"
            android:exported="true"
            android:launchMode="singleTask"
            android:label="@string/app_name"
            android:theme="@style/Theme.课程表"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity-alias
            android:name=".ImportAlias"
            android:targetActivity=".ui.activities.MainActivity"
            android:exported="true"
            android:label="导入课程表"
            android:theme="@style/Theme.课程表">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:mimeType="application/json" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/json" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:mimeType="text/calendar" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/calendar" />
            </intent-filter>
        </activity-alias>
        <activity
            android:name=".ui.activities.CourseTimeSettingsActivity"
            android:exported="false"
            android:label="课表时间设置"
            android:theme="@style/Theme.课程表"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.activities.CourseManageActivity"
            android:exported="false"
            android:label="课程管理"
            android:theme="@style/Theme.课程表" />
        <activity
            android:name=".ui.activities.CourseReminderActivity"
            android:exported="false"
            android:label="课程提醒"
            android:theme="@style/Theme.课程表"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.activities.WidgetIntroActivity"
            android:exported="false"
            android:label="桌面小部件"
            android:theme="@style/Theme.课程表" />
        <activity
            android:name=".ui.activities.SwitchScheduleActivity"
            android:exported="false"
            android:label="切换课表"
            android:theme="@style/Theme.课程表"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.activities.AboutActivity"
            android:exported="false"
            android:label="关于应用"
            android:theme="@style/Theme.课程表" />
        <activity
            android:name=".ui.activities.AppreciateAuthorActivity"
            android:exported="false"
            android:label="赞赏作者"
            android:theme="@style/Theme.课程表" />
        <activity
            android:name=".ui.activities.ChangelogActivity"
            android:exported="false"
            android:label="更新日志"
            android:theme="@style/Theme.课程表" />
        <activity
            android:name=".ui.activities.UpdateSettingsActivity"
            android:exported="false"
            android:label="更新设置"
            android:theme="@style/Theme.课程表" />
        <activity
            android:name=".ui.activities.PreferenceSettingsActivity"
            android:exported="false"
            android:label="偏好设置"
            android:theme="@style/Theme.课程表" />
        <activity
            android:name=".ui.activities.WebDavSettingsActivity"
            android:exported="false"
            android:label="WebDAV 云同步"
            android:theme="@style/Theme.课程表"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.activities.EducationalImportActivity"
            android:exported="false"
            android:label="教务系统导入"
            android:theme="@style/Theme.课程表"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.activities.AiImportActivity"
            android:exported="false"
            android:label="AI 文本导入"
            android:theme="@style/Theme.课程表"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.activities.CourseDataManageActivity"
            android:exported="false"
            android:label="备份与迁移"
            android:theme="@style/Theme.课程表"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.activities.LocalBackupActivity"
            android:exported="false"
            android:label="本地备份"
            android:theme="@style/Theme.课程表"
            android:windowSoftInputMode="adjustResize" />


        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <receiver
            android:name=".reminder.AlarmReceiver"
            android:exported="false" />

        <receiver
            android:name=".reminder.IslandExpandReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.haooz.chedule.ACTION_ISLAND_EXPAND" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".reminder.WidgetRefreshReceiver"
            android:exported="false" />

        <receiver
            android:name=".reminder.CourseStartReceiver"
            android:exported="false" />
        <receiver
            android:name=".reminder.BootCompletedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".widget.CourseWidgetProviderStandard"
            android:exported="true"
            android:label="课程提醒(标准)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_course_reminder_standard" />
        </receiver>

        <receiver
            android:name=".widget.CourseWidgetProvider"
            android:exported="true"
            android:label="课程提醒(4×6)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_course_schedule" />
        </receiver>

        <receiver
            android:name=".widget.CourseWidgetProvider4x7"
            android:exported="true"
            android:label="课程提醒(4×7)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_course_schedule_4x7" />
        </receiver>

        <receiver
            android:name=".widget.TodayCourseWidgetProviderStandard"
            android:exported="true"
            android:label="今日课程(标准)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_today_course_standard" />
        </receiver>

        <receiver
            android:name=".widget.TodayCourseWidgetProvider"
            android:exported="true"
            android:label="今日课程(4×6)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_today_course" />
        </receiver>

        <receiver
            android:name=".widget.TodayCourseWidgetProvider4x7"
            android:exported="true"
            android:label="今日课程(4×7)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_today_course_4x7" />
        </receiver>
    </application>

</manifest>